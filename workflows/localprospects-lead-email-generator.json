      "typeVersion": 4.3,
      "position": [
        800,
        -180
      ],
      "id": "35e0a33a-18be-4ce2-8b2b-a462cf478d71",
      "name": "Get enriched results"
    },
    {
      "parameters": {
        "jsCode": "const body = $json;\nconst results = Array.isArray(body.results)\n  ? body.results\n  : Array.isArray(body.data?.results)\n    ? body.data.results\n    : Array.isArray(body.businesses)\n      ? body.businesses\n      : [];\n\nif (!results.length) {\n  return [];\n}\n\nconst search = $node[\"Start LocalProspects search\"].json || {};\nconst form = $node[\"On form submission\"].json || {};\n\nreturn results.map((lead, index) => ({\n  json: {\n    ...lead,\n    localprospects_meta: {\n      job_id: search.job_id,\n      keyword: form.keyword,\n      location_code: Number(form.location_code),\n      lead_index: index + 1,\n      total_leads: results.length\n    }\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1040,
        -180
      ],
      "id": "3ca45520-8d01-4530-b062-a0e25bad1a52",
      "name": "Create one item per lead"
    },
    {
      "parameters": {
        "modelId": {
          "__rl": true,
          "value": "chat-latest",
          "mode": "list",
          "cachedResultName": "CHAT-LATEST"
        },
        "responses": {
          "values": [
            {
              "role": "system",
              "content": "You are an expert cold email copywriter for a small SEO agency. Use only facts present in the lead data. Do not invent names, rankings, traffic numbers, or website problems. Write plain text with no markdown."
            },
            {
              "role": "user",
              "content": "={{ `Write one personalized outreach email for this LocalProspects lead.\n\nOffer: a practical local SEO tune-up for service businesses: Google Business Profile cleanup, service/location pages, technical SEO fixes, schema, review/reputation improvements, and conversion fixes that help turn search visitors into calls.\n\nUse any helpful fields in the lead JSON, including business name, website, categories, address, rating, reviews, emails, phones, social links, GBP URL, website text, headings, meta description, technologies, and other enrichment fields. If a field is missing, ignore it.\n\nOutput exactly:\nSubject: ...\nEmail:\nHi ...,\n\n...\n\nRules:\n- Under 130 words.\n- Mention one specific detail from the lead when available.\n- Sound human and lightly personalized, not spammy.\n- Do not claim you audited the site unless the JSON contains enough website details.\n- Do not mention LocalProspects, n8n, or the JSON.\n- Use a generic signoff with \"Bennett\" as the sender.\n\nLead JSON:\n${JSON.stringify($json, null, 2)}` }}"
            }
          ]
        },
        "builtInTools": {},
        "options": {}
