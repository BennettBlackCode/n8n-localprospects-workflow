      "name": "Poll job status"
    },
    {
      "parameters": {
        "jsCode": "const status = String($json.status || '').toLowerCase();\nconst failedStatuses = ['failed', 'error', 'cancelled', 'canceled'];\n\nif (failedStatuses.includes(status)) {\n  const detail = $json.error || $json.message || 'No error detail returned by the API.';\n  throw new Error(`LocalProspects job ended with status \"${$json.status}\": ${detail}`);\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        320,
        -80
      ],
      "id": "0bba8136-6f0a-4d3c-8200-6f276387f8d9",
      "name": "Stop on failed job"
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 3
          },
          "conditions": [
            {
              "id": "c1cc96f4-8431-4687-8c7e-a601f719daff",
              "leftValue": "={{ $json.status }}",
              "rightValue": "completed",
              "operator": {
                "type": "string",
                "operation": "equals",
                "name": "filter.operator.equals"
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.3,
      "position": [
