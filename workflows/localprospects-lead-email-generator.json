    {
      "parameters": {
        "url": "={{ 'https://localprospects.ai/api/v1/job/' + $node['Start LocalProspects search'].json.job_id + '/results' }}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "x-api-key",
              "value": "YOUR_LOCALPROSPECTS_API_KEY"
            }
